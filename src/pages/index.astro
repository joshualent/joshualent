---
import BaseLayout from "../layouts/BaseLayout.astro";
import Project from "../components/Project.astro";
import BlogPost from "../components/BlogPost.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("blog");
const pageTitle = "joshua lent";
const description =
  "Student, developer, and nerd. I like making stuff for the web.";
---

<BaseLayout pageTitle={pageTitle} description={description}>
  <header class="space-y-2">
    <h1
      class="text-3xl font-semibold tracking-tight text-zinc-900 dark:text-zinc-50"
    >
      {pageTitle}
    </h1>
    <p class="text-lg leading-relaxed text-zinc-600 dark:text-zinc-400">
      {description}
    </p>
  </header>

  <section class="text-zinc-700 dark:text-zinc-300">
    <p class="mb-8 font-mono text-lg leading-relaxed">Welcome.</p>
  </section>

  <section class="space-y-2 text-zinc-700 dark:text-zinc-300">
    <h2
      class="mb-1 text-2xl font-semibold tracking-tight text-zinc-900 dark:text-zinc-50"
    >
      Blog posts
    </h2>
    {
      allPosts.map((post) => (
        <BlogPost url={`/posts/${post.id}/`} title={post.data.title} />
      ))
    }
  </section>

  <section class="space-y-3 text-zinc-700 dark:text-zinc-300">
    <h2
      id="projects"
      class="text-2xl font-semibold tracking-tight text-zinc-900 dark:text-zinc-50"
    >
      Projects
    </h2>
    <Project
      title="Django CVE Demo"
      url="https://github.com/joshualent/django-cve-2025-64459"
      description="Demo application used in computer club CVE presentation"
    />
    <Project
      title="My blog"
      url="https://github.com/joshualent/joshualent"
      description="this site lol"
    />
  </section>

  <p
    class="mt-12 text-center text-sm italic text-zinc-500 dark:text-zinc-500"
  >
    <em>"Maybe one day I'll be a real portfolio" said the webpage</em>
  </p>
</BaseLayout>
